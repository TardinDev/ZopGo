# Clerk Authentication
# Copy this file to .env and add your Clerk Publishable Key
# DO NOT commit .env to version control!
# PRODUCTION: use pk_live_* (not pk_test_*)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Expo Push (optional — avoids rate limits)
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# Google Gemini (AI Assistant)
# PRODUCTION: use a key with appropriate quotas from https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# --- Payments (Edge Functions "payments-initiate" + "payments-webhook") -
# Server-side secrets — set them on the Supabase Edge Function environment
# (`npx supabase secrets set ...`), NOT in the mobile bundle.
#
# PAYMENTS_MODE selects the behaviour of payments-initiate:
#   test (DEFAULT) — simulation: writes status='succeeded' immediately +
#                    sends the receipt. Keeps the booking flow working while
#                    providers are wired. Provider keys are NOT needed.
#   live           — real routing: mobile money → Singpay, paypal → PayPal,
#                    writes status='processing'; the payment is settled
#                    asynchronously by payments-webhook. Requires the keys
#                    below + a sandbox e2e pass before go-live.
PAYMENTS_MODE=test

# Singpay (Airtel Money + Moov Money aggregator) — Gabon.
# ⚠️ Adapter is a documented STUB (singpayInitiate / handleSingpay) — fill
# in the real contract from the Singpay merchant docs before live.
SINGPAY_API_URL=https://api.singpay.ga/v1
SINGPAY_API_KEY=your_singpay_api_key_here
SINGPAY_WEBHOOK_SECRET=your_singpay_webhook_secret_here

# PayPal REST API (Orders v2). Note: PayPal does NOT support XAF — send USD
# or EUR for the paypal method.
PAYPAL_BASE=https://api-m.sandbox.paypal.com  # use https://api-m.paypal.com in prod
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here   # from the PayPal app webhook config
# Deep link the PayPal approval flow returns to (handled by the app).
APP_RETURN_URL=zopgo://payments/return

# Resend (transactional email — sends the payment receipt to the payer).
# Without RESEND_API_KEY the Edge Functions log the receipt body instead,
# and still mark `receipt_sent_at`. Add the key to switch to real delivery.
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM=ZopGo <onboarding@resend.dev>  # change to a verified domain in prod
