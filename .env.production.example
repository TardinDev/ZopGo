# Production Environment Variables
# Ces variables doivent être configurées comme secrets EAS Build
# Commande : eas secret:create --scope project --name VARIABLE_NAME --value "valeur"

# Clerk Authentication (OBLIGATOIRE)
# Utilisez pk_live_* pour la production (pas pk_test_*)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_production_key_here

# Supabase (OBLIGATOIRE)
EXPO_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_production_supabase_anon_key_here

# Google Gemini AI (Optionnel - pour l'assistant IA)
# Utilisez une clé avec quotas appropriés depuis https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_production_gemini_key_here

# Expo Access Token (Optionnel - évite les rate limits pour les notifications push)
EXPO_ACCESS_TOKEN=your_expo_access_token_here
