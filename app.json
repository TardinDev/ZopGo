{
  "expo": {
    "name": "ZopGo",
    "slug": "ZopGo",
    "version": "1.0.0",
    "scheme": "zopgo",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/ZOPGO_new_design_assets/zopgo_ic_launcher.png",
          "color": "#2162FE",
          "defaultChannel": "default"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/ZOPGO_new_design_assets/zopgo_app_icon_1024.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1218"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zopgo.app"
    },
    "android": {
      "package": "com.zopgo.app",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/ZOPGO_new_design_assets/zopgo_adaptive_foreground_432.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "9b571b9b-30f7-4b83-92cd-4f0630badaae"
      }
    },
    "owner": "tardin"
  }
}
