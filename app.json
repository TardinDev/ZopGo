{
  "expo": {
    "name": "ZopGo",
    "slug": "ZopGo",
    "version": "1.0.0",
    "scheme": "zopgo",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos pour définir votre photo de profil.",
          "cameraPermission": "L'application a besoin d'accéder à votre caméra pour prendre une photo de profil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/ZOPGO_new_design_assets/zopgo_notification_icon.png",
          "color": "#2162FE",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/ZOPGO_new_design_assets/zopgo_app_icon_1024.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1218"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zopgo.app"
    },
    "android": {
      "package": "com.zopgo.app",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/ZOPGO_new_design_assets/zopgo_adaptive_foreground_432.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "0fa2c027-7583-499a-b7e5-3a320db18af6"
      },
      "clerkPublishableKey": "${EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY}",
      "supabaseUrl": "${EXPO_PUBLIC_SUPABASE_URL}",
      "supabaseAnonKey": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
      "geminiApiKey": "${EXPO_PUBLIC_GEMINI_API_KEY}"
    },
    "owner": "tardin"
  }
}
